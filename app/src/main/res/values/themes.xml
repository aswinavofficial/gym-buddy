<resources>
    <style name="Theme.GymBuddy.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_seed</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.GymBuddy</item>
    </style>

    <style name="Theme.GymBuddy" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/surface</item>
    </style>
</resources>
